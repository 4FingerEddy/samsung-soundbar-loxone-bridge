# Portainer environment variables for samsung-soundbar-bridge
# Copy these into Portainer stack environment variables.
# Do not commit real secrets. BRIDGE_AUTH_TOKEN is your private bridge password/token.

# Required: IP address or DNS name of the Samsung Soundbar.
# Recommended: reserve this IP in the router/DHCP server so it does not change.
SOUNDBAR_HOST=192.0.2.10

# Usually do not change these for Samsung local IP control.
SOUNDBAR_PORT=1516
SOUNDBAR_SCHEME=https
SOUNDBAR_VERIFY_SSL=false
SOUNDBAR_TIMEOUT_SECONDS=5
SOUNDBAR_RETRY_ON_TOKEN_ERROR=true

# Bridge HTTP listener inside the container / host-networked deployment.
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8088
BRIDGE_AUTH_MODE=query_or_header

# Required: generate a long random value, e.g. with deployment/token-generator.html.
# Do not leave this empty and do not use this example value in production.
BRIDGE_AUTH_TOKEN=REPLACE_WITH_STRONG_RANDOM_TOKEN

# Logging.
LOG_LEVEL=INFO
LOG_JSON=false

# Production default: off. Enable only temporarily for controlled debug tests.
DEBUG_ENDPOINTS=false

# Sound mode mappings. Keep these defaults unless your model was verified differently.
SOUNDBAR_MODE_STANDARD=STANDARD
SOUNDBAR_MODE_SURROUND=SURROUND
SOUNDBAR_MODE_GAME=GAME
SOUNDBAR_MODE_ADAPTIVE=ADAPTIVE
